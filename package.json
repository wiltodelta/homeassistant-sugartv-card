{
    "name": "homeassistant-sugartv-card",
    "version": "0.10.11",
    "description": "A custom Lovelace card for Home Assistant that displays CGM (Continuous Glucose Monitor) data. Supports Dexcom, Nightscout, LibreView, LibreLink, and Carelink (Medtronic) with automatic trend detection.",
    "type": "module",
    "main": "dist/sugartv-card.js",
    "scripts": {
        "build": "rollup -c",
        "watch": "rollup -c --watch",
        "demo": "npm run build && node demo/server.js",
        "demo:build": "npm run build && echo 'Demo ready! Run npm run demo to start server'",
        "format": "prettier --write .",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wiltodelta/homeassistant-sugartv-card.git"
    },
    "keywords": [
        "home-assistant",
        "homeassistant",
        "hass",
        "automation",
        "lovelace",
        "custom-cards"
    ],
    "author": "wiltodelta",
    "license": "MIT",
    "devDependencies": {
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-replace": "^6.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "prettier": "^3.8.3",
        "rollup": "^4.60.1",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "lit": "^3.3.2"
    }
}
